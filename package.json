{
  "name": "domain-reminder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bun-based CLI that sends Telegram reminders when domains are close to expiry.",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bun --version",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "bun-types": "^1.2.2",
    "typescript": "^5.7.3"
  }
}
