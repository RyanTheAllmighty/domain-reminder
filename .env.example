# Copy this file to ".env" and fill in values.
# Never commit your real ".env".

# --- Domains ---
# Comma-separated list of domains to monitor.
DOMAINS=example.com,example.net

# Daily check time in the container timezone (HH:mm, 24-hour time).
CHECK_TIME=00:00

# Comma-separated threshold days. A domain with 6 days remaining matches 7.
NOTIFY_THRESHOLDS_DAYS=30,14,7

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional behavior ---
DATA_DIR=./data
LOG_LEVEL=info
